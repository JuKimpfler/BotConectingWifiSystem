{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BotConnectingWifiSystem Config",
  "description": "Runtime configuration stored in LittleFS on ESP_Hub",
  "version": 1,
  "type": "object",
  "required": ["version", "channel", "peers"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version – increment on breaking changes",
      "default": 1
    },
    "channel": {
      "type": "integer",
      "description": "ESP-NOW / WiFi channel (1-13)",
      "minimum": 1,
      "maximum": 13,
      "default": 6
    },
    "pmk": {
      "type": "string",
      "description": "ESP-NOW Primary Master Key (16-byte hex string, stored in NVS)",
      "pattern": "^[0-9a-fA-F]{32}$",
      "default": ""
    },
    "peers": {
      "type": "array",
      "description": "Registered satellite peers",
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "role", "mac"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable device name",
            "maxLength": 16,
            "default": ""
          },
          "role": {
            "type": "string",
            "enum": ["SAT1", "SAT2"],
            "description": "Device role identifier"
          },
          "mac": {
            "type": "string",
            "description": "MAC address as XX:XX:XX:XX:XX:XX",
            "pattern": "^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$",
            "default": ""
          },
          "ltk": {
            "type": "string",
            "description": "ESP-NOW Local Traffic Key for this peer (16-byte hex, stored in NVS)",
            "pattern": "^([0-9a-fA-F]{32})?$",
            "default": ""
          }
        }
      }
    },
    "ui": {
      "type": "object",
      "description": "Web UI preferences",
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["dark", "light"],
          "default": "dark"
        },
        "rate_limit_ms": {
          "type": "integer",
          "description": "Minimum interval between UI command sends (ms)",
          "minimum": 10,
          "maximum": 1000,
          "default": 20
        },
        "mode_labels": {
          "type": "array",
          "description": "Display labels for Mode channels 1..5 (UI only)",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "string",
            "maxLength": 24
          },
          "default": ["Mode 1", "Mode 2", "Mode 3", "Mode 4", "Mode 5"]
        },
        "cal_labels": {
          "type": "array",
          "description": "Display labels for Calibration channels 1..5 (UI only)",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "string",
            "maxLength": 24
          },
          "default": ["Calib 1", "Calib 2", "Calib 3", "Calib 4", "Calib 5"]
        }
      }
    },
    "telemetry": {
      "type": "object",
      "description": "Telemetry throttling settings",
      "properties": {
        "max_rate_hz": {
          "type": "integer",
          "description": "Maximum telemetry forwarding rate to UI (Hz)",
          "minimum": 1,
          "maximum": 50,
          "default": 20
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "description": "Heartbeat settings",
      "properties": {
        "interval_ms": {
          "type": "integer",
          "description": "Heartbeat send interval (ms)",
          "minimum": 500,
          "maximum": 5000,
          "default": 1000
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Peer offline timeout (ms)",
          "minimum": 1000,
          "maximum": 30000,
          "default": 4000
        }
      }
    }
  }
}
